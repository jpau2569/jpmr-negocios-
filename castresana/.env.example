# ============================================================================
# CASTRESANA — Variables de entorno
# Copia este archivo a .env.local y rellena con los valores de tu proyecto
# Firebase (Consola → Configuración del proyecto → Tus apps → Web).
#
# SIN estas variables la app arranca igualmente en MODO DEMO (datos seed
# locales, sin login). Con ellas, se activan Auth + Firestore + FCM.
# ============================================================================

# --- Firebase Web App (públicas: van al navegador, NO son secretos) ---------
NEXT_PUBLIC_FIREBASE_API_KEY=
NEXT_PUBLIC_FIREBASE_AUTH_DOMAIN=
NEXT_PUBLIC_FIREBASE_PROJECT_ID=
NEXT_PUBLIC_FIREBASE_STORAGE_BUCKET=
NEXT_PUBLIC_FIREBASE_MESSAGING_SENDER_ID=
NEXT_PUBLIC_FIREBASE_APP_ID=

# Clave VAPID para Web Push (Consola → Cloud Messaging → Certificados push web)
NEXT_PUBLIC_FIREBASE_VAPID_KEY=

# --- Scripts de seed (SOLO servidor / terminal, nunca en el navegador) ------
# Opción A: emulador local (recomendado en desarrollo; no necesita credenciales)
#   firebase emulators:start --only firestore,auth
# FIRESTORE_EMULATOR_HOST=127.0.0.1:8080

# Opción B: proyecto real con cuenta de servicio
#   Consola → Configuración → Cuentas de servicio → Generar nueva clave privada
#   Guarda el JSON FUERA del repositorio.
# GOOGLE_APPLICATION_CREDENTIALS=/ruta/absoluta/serviceAccount.json

# Id de proyecto para los scripts (si no se puede inferir de las credenciales)
# FIREBASE_PROJECT_ID=castresana-dev
